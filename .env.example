# ==========================================
# MiniMartPro Environment Variables Config
# ==========================================
# Copy this file to a new file named '.env' for local development.
# When deploying to Vercel, configure these key-value pairs in the Vercel Dashboard project settings.

# [Flask Config]
# A secure, random secret key for session encryption
SECRET_KEY=replace_with_a_secure_random_string

# [Database Config - Supabase PostgreSQL]
# Replace with your Supabase Transaction/Session pooler connection string.
# Example: postgresql://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://username:password@supabase-host-address:port/database_name

# [AI Assistant Config]
# Your Gemini API Key from Google AI Studio (needed for AI chatbot to work)
GEMINI_API_KEY=your_gemini_api_key_here

# [Email SMTP Config]
# Credentials for sending registration OTP verification emails via SMTP (e.g. Gmail)
# If using Gmail, generate an 'App Password' from Google Account security settings.
MAIL_USERNAME=your_email_address@gmail.com
MAIL_PASSWORD=your_email_app_password
